<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI24.NewPage2"
             Title="NewPage2">
    <VerticalStackLayout Spacing="10" WidthRequest="800">
        <Label 
            Text="Zadanie3"
            FontSize="32"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Editor
            x:Name="WpisEditor"
            Placeholder="Wpisz tu swoją notatke"
            SemanticProperties.Hint="Type something to save" />
        <CollectionView
            x:Name="NotatkiCollectionView"
            ItemsSource="{Binding Pliki}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="10">
                        <Label Text="{Binding Nazwa}" FontSize="18" />
                        <Label Text="{Binding Rozmiar}" FontSize="14" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>