<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI24.NewPage1"
             Title="NewPage1">

    <VerticalStackLayout>
        <Label 
            Text="Zadanie 2"
            FontSize="32"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Editor
            x:Name="WpisEditor"
            Placeholder="Wpisz tu swoją notatke"
            SemanticProperties.Hint="Type something to save" />

        <Button
            x:Name="DodajWpisButton"
            Text="Dodaj Wpis" 
            Clicked="DodajWpisClicked"
            HorizontalOptions="Fill" />

        <Button
            x:Name="WyczyscButton"
            Text="Wyczyść dziennik"
            Clicked="WyczyscClicked"
            HorizontalOptions="Fill" />
        <ScrollView>
            <Label
            x:Name="DziennikLabel"
            HorizontalOptions="Fill" />
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>