<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI24.NewPage3"
             Title="NewPage3">
    <VerticalStackLayout>
        <Label 
            Text="Zadanie4"
            VerticalOptions="Center" 
            FontSize="32"
            HorizontalOptions="Center" />

        <Editor
            x:Name="NotatkaEditor"
            Placeholder="Wpisz tu swoją notatke"/>
        <Button
            x:Name="EksportButton"
            Text="Eksportuj" 
            Clicked="EksportClicked"
            HorizontalOptions="Fill" />

        <Button
            x:Name="ImportButton"
            Text="Importuj"
            Clicked="ImportClicked"
            HorizontalOptions="Fill" />
        <Label x:Name="OperacjeLabel"/>
        
    </VerticalStackLayout>
</ContentPage>